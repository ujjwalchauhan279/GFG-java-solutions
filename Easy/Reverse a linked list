class Solution {
    Node reverseList(Node head) {
        Node curr=head;
        Node prev=null;
        Node fwd=null;
        while(curr!=null){
            fwd=curr.next;
            curr.next=prev;
            prev=curr;
            curr=fwd;
        }
        return prev;
    }
}
