class Solution {
    public Node reverse(Node head) {
        Node curr = head;
        Node prev=null;
        Node fwd=null;
        while(curr!=null){
            fwd=curr.next;
            curr.next=prev;
            curr.prev=fwd;
            prev=curr;
            curr=fwd;
        }
        return prev;
    }
}
