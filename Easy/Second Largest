/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Find the maximum element in array.
2. Traverse again to find the largest element ≠ max.
3. Return that as second largest

*/


class Solution {
    public int getSecondLargest(int[] arr) {
        int max=-1;
        for(int i=0; i<arr.length; i++){
            if(max<arr[i]) max=arr[i];
        }
        int secmax=-1;
        for(int i=0; i<arr.length; i++){
            if(secmax<arr[i] && arr[i]!=max) secmax=arr[i];
        }
        return secmax;
    }
}
