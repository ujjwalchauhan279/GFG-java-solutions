/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Use two pointers:
    i = 0 (start)
    j = n-1 (end)
2. Swap arr[i] and arr[j].
3. Move:
    i++
    j--
4. Repeat until they meet.

*/



class Solution {
    public void reverseArray(int arr[]) {
        // code here
        int i=0;
        int j=arr.length-1;
        while(i<=j){
            int temp = arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            i++;
            j--;
        }
    }
}
