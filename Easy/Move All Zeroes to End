/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Initialize pointer k = 0 (position to place next non-zero)
2. Traverse the array
3. If current element is non-zero:
4. Swap it with element at k
5. Increment k
6. Continue till end

*/




class Solution {
    void pushZerosToEnd(int[] arr) {
        int k=0;
        for(int i=0; i<arr.length; i++){
            if(arr[i]!=0){
                int temp=arr[i];
                arr[i]=arr[k];
                arr[k]=temp;
                k++;
            }
        }
    }
}
